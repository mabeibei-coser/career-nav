        {
          "id": "P-14",
          "context": "work",
          "text": "在工作中带过新人或指导过同事时，我能耐心讲解，不会让对方听完还一脸懵",
          "reverse": false,
          "weights": { "communication": 0.8, "collaboration": 0.7 }
        }
      ]
